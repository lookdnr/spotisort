# ---------------------------------------------------------------------------
# Spotisort configuration
#
# Copy this file to `.env` and fill in your own values:
#     cp .env.example .env
#
# Create an app at https://developer.spotify.com/dashboard to obtain a client
# ID and secret, then add the redirect URI below to that app's settings.
# ---------------------------------------------------------------------------

# Required: credentials from your Spotify developer application.
SPOTIFY_CLIENT_ID=your-client-id-here
SPOTIFY_CLIENT_SECRET=your-client-secret-here

# Required: must exactly match a Redirect URI registered on your Spotify app.
# For local CLI use the loopback address below is the conventional choice.
SPOTIFY_REDIRECT_URI=http://127.0.0.1:8888/callback

# Optional: where the OAuth token is cached between runs.
# Defaults to `.cache-spotisort` in the current working directory if unset.
SPOTISORT_TOKEN_CACHE_PATH=.cache-spotisort

# Optional: logging verbosity (DEBUG, INFO, WARNING, ERROR, CRITICAL).
# Defaults to INFO if unset.
SPOTISORT_LOG_LEVEL=INFO
